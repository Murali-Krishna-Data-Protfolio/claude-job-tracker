~$*.xlsx

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Claude Code local settings (machine-specific) ────────────────────────────
.claude/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
